@model BusinessObject.ViewModel.InnerPageViewModel

<section class="inner-page">
    <h1>@Model.InnerPage.Title</h1>
    <p>@Model.InnerPage.Summary</p>
    <div>@Html.Raw(Model.InnerPage.ContentBody)</div>
</section>

<hr />

<section class="related-products">
    <h2>Related Products</h2>

    @if (Model.RelatedProducts != null && Model.RelatedProducts.Any())
    {
        <div class="row">
            @foreach (var product in Model.RelatedProducts)
            {
                <div class="col-md-3 mb-4">
                    <div class="card">
                        <img src="@product.ImagePath" class="card-img-top" alt="@product.ProductName" />
                        <div class="card-body">
                            <h5 class="card-title">@product.ProductName</h5>
                            <p>@product.ShortDescription</p>
                            <a href="/product-detail/@product.Slug-@product.ProductID" class="btn btn-primary">View Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p>No related products found.</p>
    }
</section>
