
@model Web.UI.Models.LoginViewModel

@{
    Layout = null;
    ViewBag.Title = "Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
    <link href="~/assets/css/login.css" rel="stylesheet" />
</head>

<body>
    <section class="login-page d-flex justify-content-center align-items-center vh-100">
        <article class="login-box p-4 shadow-lg rounded">
            <article class="content text-center">
                <picture class="d-flex align-items-center justify-content-center w-100 mb-3">
                    <img src="~/assets/images/site-logo-white.png" alt="Interconnect Solutions Logo" class="img-fluid" />
                </picture>

                <article class="user-icon mb-3">
                    <i class="fa-solid fa-user fa-2x"></i>
                </article>


				@using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, true, new { @class = "login100-form validate-form" }))
				{
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(false, "", new { @class = "text-danger mb-3" })

                    <article class="form-group mb-3">
                        <label for="Email">Email</label>
                        <article class="form-input d-flex align-items-center">
                            <i class="fa-solid fa-user me-2"></i>
                            @Html.TextBoxFor(m => m.Email, new { placeholder = "Email", @class = "form-control" })
                        </article>
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                    </article>

                    <article class="form-group mb-3">
                        <label for="Password">Password</label>
                        <article class="form-input d-flex align-items-center">
                            <span class="me-2"><i class="fa-solid fa-lock"></i></span>
                            @Html.PasswordFor(m => m.Password, new { placeholder = "Password", @class = "form-control" })
                            <span class="eye-icon ms-2"><i class="fa-solid fa-eye-slash"></i></span>
                        </article>
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                    </article>

                    <div class="mb-3 text-end">
                        <a href="#" class="forgot">Forgot Password?</a>
                    </div>

                    <button type="submit" class="login-btn btn btn-primary w-100">
                        LOGIN <i class="fa-solid fa-arrow-right"></i>
                    </button>
                }
            </article>
        </article>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>



















