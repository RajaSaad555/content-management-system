<script>
    document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll(".read-more-btn").forEach(function (btn) {
            btn.addEventListener("click", function () {
                let container = btn.closest(".right-navbar-top-content");
                let extended = container.querySelector(".extended-desc");

                if (extended.classList.contains("d-none")) {
                    extended.classList.remove("d-none");
                    btn.textContent = "Read Less";
                } else {
                    extended.classList.add("d-none");
                    btn.textContent = "Read More";
                }
            });
        });
    });
</script>


<script>
     function submitQuickInquiry() {
        debugger;
        const form = document.getElementById("quickInquiryForm");
        if (!form) {
            console.error("Form not found!");
            return;
        }
        event?.preventDefault();
        const formData = new FormData(form);
        const actionUrl = '/QuickInquiry/Submit';
        try {
            const response = fetch(actionUrl, {
                method: "POST",
                body: formData,
                headers: {
                    "X-Requested-With": "XMLHttpRequest"
                }
            });
            console.log("Response received:", response.status);
            const result = response;
            console.log("Parsed result:", result);
            if (result.success) {
                console.log("Success! Showing alert...");
                toastr.success(result.message, "Success!");
                form.reset();
                const modal = form.closest('.modal');
                if (modal) {
                    const bootstrapModal = bootstrap.Modal.getInstance(modal);
                    if (bootstrapModal) {
                        bootstrapModal.hide();
                    }
                }
            } else {
                console.log("Validation failed:", result.message);
                toastr.warning(result.message, "Validation Error");
            }
        } catch (error) {
            console.error("Error submitting inquiry:", error);
            toastr.error("Something went wrong while submitting your inquiry. Check console for details.", "Error");
        }
    }
</script>
