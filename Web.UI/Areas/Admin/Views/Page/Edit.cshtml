@model BusinessObject.ViewModel.CMSPageViewModel
@{


    ViewBag.PageTitle = Html.Raw(" Edit  Page "+ Model.Title);

    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    ViewBag.Pages = true;
}
@section Head {
    <link href="https://cdnjs.cloudflare.com/ajax/libs/summernote/0.8.11/summernote-bs4.css" rel="stylesheet" />
}
<!-- Page Content -->
<h1 class="h3 d-inline">@ViewBag.PageTitle</h1>
<hr />
@using (Html.BeginForm())
{
    <div class="row">
        <div class="col-lg-12 col-md-12 mb-3">
            <div class="card">
                <div class="card-body">
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.Id)
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                    <div class="row">
                        <div class="form-group col-6">
                            @Html.LabelFor(model => model.Title, "Page Title")
                            @Html.EditorFor(model => model.Title, new { htmlAttributes = new { @class = "form-control", @autofocus = "autofocus", @placeholder = "Title" } })
                            @Html.ValidationMessageFor(model => model.Title, "", new { @class = "text-danger" })
                        </div>
                     


                        <div class="form-group col-6">
                            <label for="PageId">Selected Page</label>
                            @Html.DropDownListFor(m => m.ParentId, (List<SelectListItem>)ViewBag.CmsPages, new { @class = "form-control" })
                        </div>



                    </div>
                    <div class="row">
                        <div class="form-group col-6">
                            @Html.LabelFor(model => model.Slug, "Page Slug (Friendly Name)")
                            @Html.EditorFor(model => model.Slug, new { htmlAttributes = new { @class = "form-control", @autofocus = "autofocus", @placeholder = "Slug" } })
                            @Html.ValidationMessageFor(model => model.Slug, "", new { @class = "text-danger" })
                        </div>

                        <div class="form-group col-6">
                            @Html.LabelFor(model => model.Summary, "Page Summary")
                            @Html.EditorFor(model => model.Summary, new { htmlAttributes = new { @class = "form-control", @autofocus = "autofocus", @placeholder = "Summary" } })
                            @Html.ValidationMessageFor(model => model.Summary, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row">

                        <hr />
                    </div>
                    <div class="row">
                        <div class="form-group col-6">
                            @Html.LabelFor(model => model.MetaKeywords, "Meta Keywords")
                            @Html.EditorFor(model => model.MetaKeywords, new { htmlAttributes = new { @class = "form-control", @autofocus = "autofocus", @placeholder = "Meta Keywords" } })
                            @Html.ValidationMessageFor(model => model.MetaKeywords, "", new { @class = "text-danger" })
                        </div>
                        <div class="form-group col-6">
                            @Html.LabelFor(model => model.MetaDescription, "Meta Description")
                            @Html.EditorFor(model => model.MetaDescription, new { htmlAttributes = new { @class = "form-control", @autofocus = "autofocus", @placeholder = "Meta Description" } })
                            @Html.ValidationMessageFor(model => model.MetaDescription, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row">

                        <div class="form-group col-12">
                        @Html.LabelFor(model => model.ContentBody, "Page Content")
                        @Html.TextAreaFor(model => model.ContentBody, new { @class = "form-control summernote", id = "Content" })
                    </div>
                    </div>
                    <div class="row">
                        <div class="form-group col-2">
                        <input type="submit" class="btn btn-primary btn-block" value="Update" />
                    </div>
                </div>
                </div>
         

            </div>
        </div>
 
    </div>
}


<script src="https://unpkg.com/aos@next/dist/aos.js"></script>
<script>
    AOS.init();
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>

@section Scripts {
    <!-- Summernote CSS and JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/summernote/0.8.18/summernote-bs4.min.js"></script>

    <script>
        $(document).ready(function () {
            $('.summernote').summernote({
                height: 400,
                    
                toolbar: [
                    ['style', ['style']],
                    ['font', ['bold', 'italic', 'underline', 'clear']],
                    ['fontname', ['fontname']],
                    ['fontsize', ['fontsize']],
                    ['color', ['color']],
                    ['para', ['ul', 'ol', 'paragraph']],
                    ['height', ['height']],
                    ['table', ['table']],
                    ['insert', ['link', 'picture', 'video']],
                    ['view', ['fullscreen', 'codeview', 'help']]
                ],
                fontNames: ['Arial', 'Arial Black', 'Comic Sans MS', 'Courier New', 'Helvetica', 'Impact', 'Lucida Grande', 'Tahoma', 'Times New Roman', 'Verdana'],
                fontSizes: ['8', '9', '10', '11', '12', '14', '16', '18', '20', '22', '24', '26', '28', '36', '48', '64', '82', '150']
            });
        });
    </script>
}