@model IEnumerable<DataAccess.Model.Slider>
@{
    ViewBag.PageTitle = "Slider";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    ViewBag.Slider = true;
}

<!-- Page Content -->
<h1 class="h3 d-inline">@ViewBag.PageTitle</h1>
<a href="@Url.Action("Create")" class="btn btn-primary align-top btn-sm"><i class="fa fa-list"></i> Add new</a>

<hr />

<div class="row mb-3">
    <div class="col-12">

        <div class="table-responsive">
            <table id="pagesTable" class="table table-bordered table-hover">
                <thead class="thead-light">
                    <tr>
                        <th>Heading text</th>

                        <th>Description text</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                @foreach (var item in Model)

                {
                    <tr>
                        <td>@item.SliderHeadingText</td>
                        <td>@item.SliderDescriptionText</td>
                        <td>
                            @Html.ActionLink("Edit", "Edit", new { id = item.SliderId }, new { @class = "text-success" }) -
                            <a href="@Url.Action("DeleteConfirmed", "Slider", new { id = item.SliderId })" class="text-danger" onclick="confirmDelete(event, this.href)">Delete</a>
                        </td>
                    </tr>
                }
            </table>
        </div>

    </div>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- ✅ jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- ✅ DataTables Bootstrap 5 CSS + JS -->
    <link href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>



    <script>

            $(document).ready(function () {
                $('#pagesTable').DataTable({
                    searching: true,   // ✅ only search bar enabled
                    paging: true,     // keep pagination off
                    ordering: true,   // keep sorting off
                    info: true,       // hide "Showing x of y entries"
                    pageLength: 10,       // ✅ number of rows per page
                    lengthMenu: [5, 10, 25, 50, 100], // ✅ dropdown to choose how many rows per page
                    language: {
                        search: "Search ", // Search label
                        lengthMenu: "Show _MENU_ entries per page", // customize length label
                        info: "Showing _START_ to _END_ of _TOTAL_ products",
                        paginate: {
                            previous: "Prev",
                            next: "Next"
                        }
                    }
                });
            });


        function confirmDelete(event, url) {
            event.preventDefault(); // stop default navigation

            Swal.fire({
                title: 'Are you sure?',
                text: "This Slider will be permanently deleted!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, delete it!',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = url; // redirect to delete action
                }
            });
        }

        // ✅ Show success alert
        @if (TempData["SuccessMessage"] != null)
        {
                        <text>
                            Swal.fire({
                                icon: 'success',
                                title: 'Success',
                                text: '@TempData["SuccessMessage"]'
                            });
                        </text>
        }

        // ✅ Show error/warning alert
        @if (TempData["ErrorMessage"] != null)
        {
                        <text>
                            Swal.fire({
                                icon: 'warning',
                                title: 'Warning',
                                text: '@TempData["ErrorMessage"]'
                            });
                        </text>
        }
    </script>




}

