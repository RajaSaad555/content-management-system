@model BusinessObject.ViewModel.ContentViewModel
@{
    ViewBag.PageTitle = "Edit Slider";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    ViewBag.Pages = true;
}

@section Head {
    <link href="https://cdnjs.cloudflare.com/ajax/libs/summernote/0.8.11/summernote-bs4.css" rel="stylesheet" />
}

<h1 class="h3 d-inline">@ViewBag.PageTitle</h1>
<hr />

@using (Html.BeginForm("Edit", "Slider", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.Slider.SliderId)
    @Html.HiddenFor(m => m.Slider.SliderImageUrl)   <!-- Keep existing image if no new file -->

    <div class="row">
        <div class="col-lg-9 col-md-12 mb-3">
            <div class="card">
                <div class="card-body">
                    <!-- Heading -->
                    <div class="form-group">
                        @Html.LabelFor(m => m.Slider.SliderHeadingText, "Heading")
                        @Html.EditorFor(m => m.Slider.SliderHeadingText, new { htmlAttributes = new { @class = "form-control", @placeholder = "Slider Heading" } })
                        @Html.ValidationMessageFor(m => m.Slider.SliderHeadingText, "", new { @class = "text-danger" })
                    </div>

                    <!-- Description -->
                    <div class="form-group">
                        @Html.LabelFor(m => m.Slider.SliderDescriptionText, "Description")
                        @Html.TextAreaFor(m => m.Slider.SliderDescriptionText, new { @class = "form-control summernote", @placeholder = "Slider Description Text" })
                        @Html.ValidationMessageFor(m => m.Slider.SliderDescriptionText, "", new { @class = "text-danger" })
                    </div>

                    <!-- Position -->
                    <div class="form-group">
                        @Html.LabelFor(m => m.Slider.SliderPosition, "Position")
                        @Html.EditorFor(m => m.Slider.SliderPosition, new { htmlAttributes = new { @class = "form-control", @placeholder = "Slider Position" } })
                        @Html.ValidationMessageFor(m => m.Slider.SliderPosition, "", new { @class = "text-danger" })
                    </div>

                    <!-- Image Upload -->
                    <div class="row">
                      <div class="form-group col-6">
                        <label for="SliderImageFile">Upload New Image</label>
                        <input type="file" asp-for="SliderImageFile" accept="image/*" onchange="previewImage(event)" />
                        @Html.ValidationMessageFor(m => m.SliderImageFile, "", new { @class = "text-danger" })
                       </div>
                        <div class="col-6">
                            <p id="previewText" style="display:@(string.IsNullOrEmpty(Model?.Slider?.SliderImageUrl) ? "none" : "block")">
                                Current Image:
                            </p>
                            <img id="filePreview"
                                 src="@(string.IsNullOrEmpty(Model?.Slider?.SliderImageUrl) ? "" : Url.Content(Model.Slider.SliderImageUrl))"
                                 alt="Slider Image"
                                 style="max-height:100px;@(string.IsNullOrEmpty(Model?.Slider?.SliderImageUrl) ? "display:none;" : "")" />
                        </div>
                    </div>

                    <!-- Link -->
                    <div class="form-group">
                        @Html.LabelFor(m => m.Slider.SliderLink, "Link")
                        @Html.EditorFor(m => m.Slider.SliderLink, new { htmlAttributes = new { @class = "form-control", @placeholder = "Slider Link" } })
                        @Html.ValidationMessageFor(m => m.Slider.SliderLink, "", new { @class = "text-danger" })
                    </div>
                </div>
                   <div class="card-footer text-right col-md-2">
                    <button type="submit" class="btn btn-primary btn-block ">Update</button>
                </div>
            </div>
        </div>
      
     
             
            </div>
     
}

@section Scripts {
    <script>
        function previewImage(event) {
            const file = event.target.files[0];
            const preview = document.getElementById('filePreview');
            const previewText = document.getElementById('previewText');

            if (file) {
                preview.src = URL.createObjectURL(file);
                preview.style.display = 'block';
                previewText.style.display = 'block';
            } else {
                preview.src = "";
                preview.style.display = 'none';
                previewText.style.display = 'none';
            }
        }
    </script>
}
