@model IEnumerable<BusinessObject.ViewModel.ProductCategoryViewModel>

@{
    ViewBag.PageTitle = "Products Categories";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    ViewBag.ProductCategories = true;
}

<h1 class="h3 d-inline">@ViewBag.PageTitle</h1>

<a href="@Url.Action("Create", "ProductCategories", new { area = "Admin" })"
   class="btn btn-primary align-top btn-sm">
    <i class="fa fa-plus"></i> Create New 
</a>

<hr />

<div class="row mb-3">
    <div class="col-12">
        <div class="table-responsive">
            <table id="pagesTable"  class="table table-bordered table-hover">
                <thead class="thead-light">
                    <tr>
                        <th>CMS Page</th>
                        <th>Category Name</th>
                        <th>Parent</th>
                        <th>Picture</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cat in Model)
                    {
                        <tr>
                            <td>@cat.CMSPageTitle</td>
                            <td>@cat.CategoryName</td>
                            <td>@cat.ParentCategoryName</td>
                            <td>
                                @{
                                    string imagePath = !string.IsNullOrEmpty(cat.ImagePath)
                                    ? Url.Content(cat.ImagePath) // Note capital 'U'
                                    : Url.Content("~/images/no-image.png"); // Make sure this exists
                                }

                                <img src="@imagePath"
                                     alt="@cat.CategoryName ?? " No image""
                                     width="60"
                                     height="60"
                                     class="img-thumbnail" />
                            </td>


   

                            <td>
                                <a href="@Url.Action("Edit", "productcategories", new { area = "Admin", id = cat.CategoryID })"
                                   class="text-success">
                                    Edit
                                </a>
                                -
                            @*     <a href="@Url.Action("Delete", "productcategories", new { area = "Admin", id = cat.CategoryID })"
                                   class="text-danger"
                                   onclick="return confirmDelete()">
                                    Delete
                                </a> *@
                                <a href="@Url.Action("Delete", "ProductCategories", new { id = cat.CategoryID })"
                                   onclick="confirmDelete(event, this.href)"
                                   class="text-danger">
                                   Delete
                                </a>

                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>



@section Scripts {




    <!-- ✅ jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- ✅ DataTables Bootstrap 5 CSS + JS -->
    <link href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>




    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>


<script>




          $(document).ready(function () {
            $('#pagesTable').DataTable({
                   searching: true,   // ✅ only search bar enabled
                   paging: true,     // keep pagination off
                   ordering: true,   // keep sorting off
                   info: true,       // hide "Showing x of y entries"
                   pageLength: 10,       // ✅ number of rows per page
                   lengthMenu: [5, 10, 25, 50, 100], // ✅ dropdown to choose how many rows per page
                   language: {
                       search: "Search", // Search label
                       lengthMenu: "Show _MENU_ entries per page", // customize length label
                       info: "Showing _START_ to _END_ of _TOTAL_ categories",
                       paginate: {
                                previous: "Prev",
                                next: "Next"
                            }
                        }
            });
        });


    function confirmDelete(event, url) {
        event.preventDefault(); // stop default navigation

        Swal.fire({
            title: 'Are you sure?',
            text: "This category will be permanently deleted!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Yes, delete it!',
            cancelButtonText: 'Cancel'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = url; // redirect to delete action
            }
        });
    }

    // ✅ Show success alert
    @if (TempData["SuccessMessage"] != null)
    {
            <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Success',
                    text: '@TempData["SuccessMessage"]'
                });
            </text>
    }

    // ✅ Show error/warning alert
    @if (TempData["ErrorMessage"] != null)
    {
            <text>
                Swal.fire({
                    icon: 'warning',
                    title: 'Warning',
                    text: '@TempData["ErrorMessage"]'
                });
            </text>
    }
</script>


}
