@model BusinessObject.ViewModel.BlogCategoryCreateViewModel

@{
    ViewBag.PageTitle = "Blog Categories";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    ViewBag.BlogCategories = true;
}

<h1 class="h3 d-inline">@ViewBag.PageTitle</h1>
<hr />


<div class="row">
    <div class="col-md-4 mb-3">
        <form asp-action="index" asp-controller="Categories" asp-area="Admin" method="post">
            @Html.AntiForgeryToken()
            <div class="card">
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.Title)
                        <input asp-for="Title" name="Title" class="form-control" autofocus />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(model => model.Slug)
                        <input asp-for="Slug" name="Slug" class="form-control" />
                        <span asp-validation-for="Slug" class="text-danger"></span>
                    </div>
                </div>

                <div class="card-footer text-right">
                    <input type="submit" class="btn btn-primary" value="Add" />
                </div>
            </div>
        </form>
    </div>

    <div class="col-md-8">
        <div class="table-responsive">
            <table id="pagesTable"  class="table table-bordered table-hover">
                <thead class="thead-light">
                    <tr>
                        <th>Name</th>
                        <th>Slug</th>
                        <th>Operations</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Categories != null && Model.Categories.Any())
                    {
                        @foreach (var item in Model.Categories)
                        {
                            <tr>
                                <td>@Html.DisplayFor(model => item.Name)</td>
                                <td>@Html.DisplayFor(model => item.Slug)</td>
                                <td>
                                    @Html.ActionLink("Edit", "Edit", new { id = item.Id }, htmlAttributes: new { @class = "text-success" }) -
                                    <a href="@Url.Action("Delete", "BlogCategories", new { id = item.Id })" class="text-danger" onclick="confirmDelete(event, this.href)">Delete</a>

                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center">No categories found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>


    <!-- ✅ jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- ✅ DataTables Bootstrap 5 CSS + JS -->
    <link href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>




    <script>
        $(document).ready(function () {
                    $('#pagesTable').DataTable({
                        searching: true,   // ✅ only search bar enabled
                        paging: true,     // keep pagination off
                        ordering: true,   // keep sorting off
                        info: true,       // hide "Showing x of y entries"
                        pageLength: 10,       // ✅ number of rows per page
                        lengthMenu: [5, 10, 25, 50, 100], // ✅ dropdown to choose how many rows per page
                        language: {
                            search: "Search:", // Search label
                            lengthMenu: "Show _MENU_ entries per page", // customize length label
                            info: "Showing _START_ to _END_ of _TOTAL_ products",
                            paginate: {
                                previous: "Prev",
                                next: "Next"
                            }
                        }
                    });
                });



        function confirmDelete(event, url) {
            event.preventDefault();

            Swal.fire({
                title: 'Are you sure?',
                text: "This Blog category will be permanently deleted!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, delete it!',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = url;
                }
            });
        }

        // ✅ Success
        @if (TempData["SuccessMessage"] != null)
        {
                <text>
                    Swal.fire({
                        icon: 'success',
                        title: 'Success',
                        text: '@TempData["SuccessMessage"]'
                    });
                </text>
        }

        // ✅ Error
        @if (TempData["ErrorMessage"] != null)
        {
                <text>
                    Swal.fire({
                        icon: 'warning',
                        title: 'Warning',
                        text: '@TempData["ErrorMessage"]'
                    });
                </text>
        }
    </script>
}


